# Uniform Project Configuration
# Copy this file to .env and fill in your values

# Your Uniform Project ID (found in Project Settings)
UNIFORM_PROJECT_ID=your-project-id-here

# Uniform API Key (create one in Project Settings > API Keys)
# Required permissions: Read Published Compositions, Read Draft Compositions
UNIFORM_API_KEY=uf_xxxxxxxxxxxxxxxxxxxx

# Optional: Port for development server (default: 5173)
# PORT=5173

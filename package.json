{
  "name": "turningstone-demo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server",
    "build": "tsc -b && npm run build:client && npm run build:server",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.jsx --outDir dist/server",
    "start": "cross-env NODE_ENV=production node server",
    "uniform:manifest": "uniform context manifest download --output ./src/uniform/contextManifest.json",
    "uniform:pull": "uniform sync pull",
    "uniform:push": "uniform sync push",
    "uniform:publish": "uniform context manifest publish"
  },
  "dependencies": {
    "@uniformdev/canvas": "^20.5.0",
    "@uniformdev/canvas-react": "^20.5.0",
    "@uniformdev/context": "^20.5.0",
    "@uniformdev/context-react": "^20.5.0",
    "compression": "^1.7.4",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sirv": "^2.0.4"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@uniformdev/cli": "^20.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^7.0.3",
    "typescript": "~5.7.0",
    "vite": "^6.1.0"
  }
}
